<style>
  :root{
    --bg:#14181A;
    --panel:#1C2224;
    --panel-2:#222A2C;
    --ink:#ECE8DE;
    --muted:#7C8386;
    --accent:#1a365d; 
    --accent-ink:#ECE8DE;
    --accent-2:#8FBF3F;
    --line: rgba(236,232,222,0.10);
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background-color:var(--bg);
    color:var(--ink);
    font-family:'JetBrains Mono', monospace;
    min-height:100vh;
    overflow-x: hidden;
  }
  h1,h2,h3,.display{
    font-family:'Oswald', sans-serif;
    text-transform:uppercase;
    letter-spacing:0.03em;
    margin:0;
  }
  .wrap{max-width:720px;margin:0 auto; padding: 20px 16px 120px;}
  .icon{width:20px; height:20px; display:block;}

  /* ---------- ANIMAÇÕES ---------- */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes pulseRunner {
    0%, 100% { transform: scale(1); opacity: 0.8; }
    50% { transform: scale(1.1); opacity: 1; fill: var(--accent-2); }
  }
  @keyframes liftWeight {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  @keyframes fillBottle {
    0% { height: 10%; }
    100% { height: 100%; }
  }

  .animated-fade {
    animation: fadeInUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* ---------- CARREGAMENTO ---------- */
  .loader-screen {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100vh;
    background: var(--bg);
    color: var(--ink);
    text-align: center;
  }
  .runner-icon {
    width: 80px;
    height: 80px;
    animation: pulseRunner 1.2s infinite ease-in-out;
    fill: var(--ink);
    margin-bottom: 20px;
  }

  /* ---------- ANIMAÇÃO DE CÁLCULO ---------- */
  .calc-loader {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 30px;
    background: var(--panel-2);
    border: 1px dashed var(--accent);
    margin-bottom: 16px;
    border-radius: 4px;
    animation: fadeInUp 0.3s ease;
  }
  .calc-anim-icons {
    display: flex;
    gap: 30px;
    margin-bottom: 15px;
    align-items: flex-end;
  }
  .anim-weight {
    width: 40px;
    height: 40px;
    fill: var(--accent-2);
    animation: liftWeight 0.8s infinite ease-in-out;
  }
  .anim-bottle-container {
    width: 20px;
    height: 40px;
    border: 2px solid var(--ink);
    border-radius: 4px;
    position: relative;
    overflow: hidden;
  }
  .anim-bottle-fill {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: #3182ce;
    animation: fillBottle 1.5s infinite ease-in-out;
  }

  /* ---------- LOGIN RÁPIDO ---------- */
  .loginWrap{max-width:420px; margin:0 auto; min-height:100vh; display:flex; flex-direction:column; justify-content:center; padding:24px;}
  .loginTitle{text-align:center; margin-bottom:6px; font-size:24px;}
  .loginTitle span{color:var(--accent);}
  .loginSub{text-align:center; color:var(--muted); font-size:11px; letter-spacing:0.1em; margin-bottom:30px;}
  
  .lockerBig{
    background:var(--panel); border:1px solid var(--line); border-top:4px solid var(--muted);
    padding:24px 18px; margin-bottom:16px; cursor:pointer; 
    transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    display: flex; flex-direction: column; align-items: center; text-align: center;
  }
  .lockerBig:hover{
    transform: translateY(-4px);
    border-top-color:var(--accent);
    background: var(--panel-2);
  }
  .lockerBig .tag{font-size:10px; color:var(--muted); letter-spacing:0.12em; margin-bottom:4px;}
  .lockerBig .name{font-family:'Oswald',sans-serif; font-size:26px; font-weight:700; text-transform: uppercase;}
  .lockerBig .hint{font-size:11px; color:var(--muted); margin-top:8px;}

  /* ---------- CONTROLES ---------- */
  .field{margin-bottom:14px;}
  .field label{display:block; font-size:11px; color:var(--muted); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:6px;}
  .color-picker-wrap { display: flex; align-items: center; gap: 10px; }
  .color-picker-wrap input[type="color"] { width: 50px; height: 38px; padding: 0; cursor: pointer; border: 1px solid var(--line); }
  input, select, textarea{
    width:100%; background:var(--bg); border:1px solid var(--line); color:var(--ink);
    padding:9px 10px; font-family:'JetBrains Mono',monospace; font-size:14px;
  }
  textarea{resize:vertical; min-height:64px;}
  input:focus, select:focus, textarea:focus{outline:1px solid var(--accent); border-color:var(--accent);}
  .btn{
    background:var(--accent); color:var(--accent-ink); border:none; padding:11px 16px; font-family:'Oswald',sans-serif;
    text-transform:uppercase; font-weight:600; letter-spacing:0.05em; cursor:pointer; font-size:13px;
    display: inline-block; text-align: center; text-decoration: none;
  }
  .btn:hover{filter:brightness(1.2);}
  .btn.ghost{background:transparent; color:var(--ink); border:1px solid var(--line);}
  .btn.ghost:hover{border-color:var(--accent); color:var(--accent);}
  .btn.small{padding:7px 10px; font-size:11px;}
  .btnRow{display:flex; gap:10px; flex-wrap:wrap; align-items:center;}
  .rowGrid{display:grid; grid-template-columns:1fr 1fr; gap:12px;}
  .panel{background:var(--panel); border:1px solid var(--line); padding:20px; margin-bottom:16px; border-radius: 4px;}
  .tear{border:none; border-top:1px dashed var(--line); margin:20px 0;}
  .empty{color:var(--muted); font-size:12px; padding:16px 0; text-align:center;}
  .iconBtn{background:none; border:none; color:var(--muted); cursor:pointer; font-size:15px; padding:2px 6px;}
  .iconBtn:hover{color:var(--accent);}
  .hint{font-size:11px; color:var(--muted); margin-top:8px; line-height:1.5;}
  .toast{position:fixed; bottom:88px; left:50%; transform:translateX(-50%); background:var(--panel-2); border:1px solid var(--accent); color:var(--ink); padding:9px 16px; font-size:12px; opacity:0; transition:opacity .25s; pointer-events:none; z-index:99;}
  .toast.show{opacity:1;}

  /* ---------- TOP HEADER ---------- */
  .topbar{display:flex; align-items:center; justify-content:space-between; padding-bottom:16px; margin-bottom:16px; border-bottom:1px solid var(--line);}
  .topbar .left{display:flex; align-items:center; gap:10px;}
  .avatar{
    width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center;
    font-family:'Oswald',sans-serif; font-weight:700; font-size:15px; cursor:pointer; border:none; flex-shrink:0;
    color: #fff !important;
  }
  .avatarSmall{width:30px; height:30px; font-size:12px;}
  .wordmark{font-size:15px; letter-spacing:0.06em;}
  .wordmark span{color:var(--accent);}
  .menuBtn{background:none; border:1px solid var(--line); color:var(--muted); font-size:11px; padding:6px 10px; cursor:pointer; font-family:'Oswald',sans-serif; text-transform:uppercase; letter-spacing:.05em;}
  .menuBtn:hover{color:var(--accent); border-color:var(--accent);}
  .menuPanel{position:fixed; top:0; right:0; bottom:0; width:280px; background:var(--panel); border-left:1px solid var(--line); z-index:70; padding:20px; transform:translateX(100%); transition:transform .2s;}
  .menuPanel.open{transform:translateX(0);}
  .menuOverlay{position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:65; opacity:0; pointer-events:none; transition:opacity .2s;}
  .menuOverlay.open{opacity:1; pointer-events:auto;}
  .menuPanel h3{font-size:14px; margin-bottom:16px;}
  .menuItem{padding:11px 0; border-bottom:1px solid var(--line); font-size:12.5px; cursor:pointer; color:var(--ink);}
  .menuItem:hover{color:var(--accent);}
  .menuItem.danger:hover{color:#ff6b6b;}

  /* ---------- BOTTOM NAV ---------- */
  .bottomNav{
    position:fixed; bottom:0; left:0; right:0; background:var(--panel); border-top:1px solid var(--line);
    display:flex; justify-content:center; z-index:40;
  }
  .bottomNavInner{max-width:720px; width:100%; display:flex;}
  .navBtn{
    flex:1; display:flex; flex-direction:column; align-items:center; gap:4px; padding:10px 4px 8px;
    background:none; border:none; cursor:pointer; color:var(--muted);
    font-family:'Oswald',sans-serif; text-transform:uppercase; font-size:9.5px; letter-spacing:0.04em;
  }
  .navBtn.active{color:var(--accent);}
  .navBtn .icon{margin:0 auto;}

  /* ---------- PLATES ---------- */
  .plates{display:flex; gap:14px; flex-wrap:wrap; margin-top:18px;}
  .plate{
    flex:1; min-width:140px; border:2px solid var(--line); border-radius:50%; aspect-ratio:1;
    display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center;
    background: radial-gradient(circle at 35% 30%, var(--panel-2), var(--panel) 70%);
  }
  .plate .val{font-family:'Oswald',sans-serif; font-size:26px; font-weight:700;}
  .plate .lbl{font-size:9px; color:var(--muted); text-transform:uppercase; letter-spacing:0.08em; margin-top:4px; padding:0 10px;}
  .plate.accent{border-color:var(--accent);}
  .plate.accent .val{color:var(--accent);}
  .plate.accent2{border-color:var(--accent-2);}
  .plate.accent2 .val{color:var(--accent-2);}

  /* ---------- LISTAS E TREINOS ---------- */
  .ledger{border-top:1px solid var(--line);}
  .ledgerRow{
    display:grid; grid-template-columns: 1fr auto; gap:10px; align-items:center;
    padding:11px 2px; border-bottom:1px solid var(--line); font-size:13px;
  }
  .ledgerRow .meta{color:var(--muted); font-size:11px;}
  .exRow{display:grid; grid-template-columns:auto 2fr 1fr 1fr 1fr auto; gap:8px; align-items:center; padding:8px 2px; border-bottom:1px solid var(--line); font-size:12.5px;}
  .exRow .h{color:var(--muted); font-size:10px; text-transform:uppercase; letter-spacing:.06em;}
  .exRow input[type=checkbox]{width:16px; accent-color:var(--accent-2);}
  .exRow.done{opacity:0.55;}
  .exRow.done .exName{text-decoration:line-through; color:var(--muted);}
  .dayCard{margin-bottom:16px; border:1px solid var(--line); border-radius: 4px; overflow: hidden;}
  .dayHead{display:flex; justify-content:space-between; align-items:center; padding:12px 14px; background:var(--panel-2); gap:10px;}
  .dayHead h3{font-size:15px;}
  .dayBody{padding:12px 14px;}

  /* ---------- WEEK STRIP ---------- */
  .weekStrip{display:flex; justify-content:space-between; gap:6px; margin-bottom:18px;}
  .dayDot{flex:1; display:flex; flex-direction:column; align-items:center; gap:6px; cursor:pointer;}
  .dayDot .lbl{font-size:9px; color:var(--muted); text-transform:uppercase;}
  .dayDot .circ{
    width:32px; height:32px; border-radius:50%; border:1.5px solid var(--line); display:flex; align-items:center; justify-content:center;
    font-family:'Oswald',sans-serif; font-size:12px; color:var(--muted);
  }
  .dayDot.done .circ{background:var(--accent-2); border-color:var(--accent-2); color:#14181A;}
  .dayDot.today .circ{border-color:var(--accent);}

  .chartWrap{width:100%; overflow-x:auto;}

  /* ---------- CRONÔMETRO FLUTUANTE ---------- */
  .timerBar{
    position:fixed; bottom:64px; left:0; right:0; background:var(--panel-2); border-top:1px solid var(--accent);
    padding:8px 16px; display:flex; align-items:center; justify-content:space-between; z-index:35;
    font-family:'JetBrains Mono',monospace; font-size:13px;
  }
  .timerBar .time{font-size:18px; font-weight:700; color:var(--accent-2);}
  .timerBar .timerBtnRow{display:flex; gap:6px;}

  /* ---------- SEÇÃO DE ÁGUA ---------- */
  .waterWidget { display: flex; align-items: center; justify-content: space-between; gap: 15px; }
  .waterProgress { flex: 1; height: 12px; background: var(--bg); border: 1px solid var(--line); border-radius: 6px; overflow: hidden; position: relative;}
  .waterBar { height: 100%; background: #3182ce; transition: width 0.3s; }

  /* ---------- HABITOS/METAS ---------- */
  .metaRow { display: flex; align-items: center; gap: 10px; padding: 10px 0; border-bottom: 1px solid var(--line); }
  .metaRow input[type="checkbox"] { width: 18px; height: 18px; accent-color: var(--accent); cursor: pointer; }
  .metaRow.done span { text-decoration: line-through; color: var(--muted); }
  .progressBar { height: 8px; background: var(--bg); border-radius: 4px; overflow: hidden; margin: 10px 0; }
  .progressBarInner { height: 100%; background: var(--accent-2); width: 0%; transition: width 0.3s; }

  /* ---------- MURAL DE POSTS ---------- */
  .postCard{background:var(--panel); border:1px solid var(--line); margin-bottom:14px; border-radius: 4px; overflow: hidden;}
  .postHead{display:flex; align-items:center; gap:10px; padding:12px 14px 8px;}
  .postHead .who{font-family:'Oswald',sans-serif; font-size:13px; text-transform:uppercase;}
  .postHead .when{font-size:10px; color:var(--muted);}
  .postText{padding:0 14px 10px; font-size:13.5px; line-height:1.5; white-space:pre-wrap;}
  .postImg{width:100%; display:block; max-height:420px; object-fit:cover; border-bottom: 1px solid var(--line);}
  .postFoot{display:flex; align-items:center; gap:10px; padding:8px 14px 12px; border-top: 1px solid var(--line); flex-wrap: wrap;}
  .likeBtn{background:none; border:1px solid var(--line); color:var(--muted); padding:6px 12px; font-size:12px; cursor:pointer; font-family:'JetBrains Mono',monospace;}
  .likeBtn.liked{border-color:var(--accent); color:var(--accent);}
  .composer textarea{margin-bottom:10px;}
  .fileRow{display:flex; align-items:center; gap:10px; margin-bottom:12px;}
  .fileRow .fname{font-size:11px; color:var(--muted);}
  .previewImg{max-width:100%; max-height:160px; margin-bottom:10px; border:1px solid var(--line); display:none;}
  
  /* Comentários */
  .commentsSec { width: 100%; background: var(--panel-2); padding: 10px 14px; font-size: 12px; border-top: 1px solid var(--line); }
  .commentInputWrap { display: flex; gap: 8px; margin-top: 8px; }
  .commentInputWrap input { padding: 6px 10px; font-size: 12px; }
  .commentRow { margin-bottom: 6px; line-height: 1.4; }
  .commentRow strong { color: var(--accent); }

  @media (max-width:480px){
    .rowGrid{grid-template-columns:1fr;}
    .exRow{grid-template-columns:auto 1.6fr 1fr 1fr 1fr auto;}
  }
</style>
</head>

        <div class="meta">${e.data}${e.cintura?` · cintura ${e.cintura}cm`:''}${e.peito?` · peito ${e.peito}cm`:''}${e.quadril?` · quadril ${e.quadril}cm`:''}${e.braco?` · braço ${e.braco}cm`:''}</div>
      </div>
      <button class="iconBtn" onclick="delProgresso('${e.id}')">✕</button>
    </div>`).join('') || `<div class="empty">Nenhum registro ainda.</div>`;
  return `
    <div class="panel animated-fade"><h3 style="margin-bottom:14px;">Evolução do peso</h3>${svgChart(list)}</div>
    <div class="panel animated-fade">
      <div class="rowGrid">

/* ---------- CRONÔMETRO ---------- */
function startTimer(seconds) {
  if (timerInterval) clearInterval(timerInterval);
  timerTimeLeft = seconds;
  timerRunning = true;
  updateTimerUI();
  
  timerInterval = setInterval(() => {
    if (timerTimeLeft > 0) {
      timerTimeLeft--;
      updateTimerUI();
    } else {
      clearInterval(timerInterval);
      timerRunning = false;
      document.getElementById('timerBeep').play();
      if(navigator.vibrate) navigator.vibrate([200, 100, 200]);
      toast("Tempo esgotado! Próxima série! 💪🔥");
      updateTimerUI();
    }
  }, 1000);
}

function toggleTimerRun() {
  if (!timerRunning && timerTimeLeft > 0) {
    timerRunning = true;
    startTimer(timerTimeLeft);
  } else {
    clearInterval(timerInterval);
    timerRunning = false;
    updateTimerUI();
  }
}

function stopTimer() {
  clearInterval(timerInterval);
  timerTimeLeft = 0;
  timerRunning = false;
  updateTimerUI();
}

function updateTimerUI() {
  const el = document.getElementById('timerContainer');
  if(!el) return;
  if(timerTimeLeft <= 0) {
    el.style.display = 'none';
    return;
  }
  el.style.display = 'flex';
  const m = Math.floor(timerTimeLeft / 60);
  const s = timerTimeLeft % 60;
  document.getElementById('timerDisplay').textContent = `${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
  document.getElementById('timerPlayBtn').textContent = timerRunning ? 'PAUSAR' : 'RETOMAR';
}


function svgChart(list){
  if(list.length < 2) return `<div class="empty">Adicione ao menos 2 registros para ver o gráfico.</div>`;
  const w = 640, h = 160, pad = 30;
  const pesos = list.map(e=>e.peso);
  const min = Math.min(...pesos) - 1, max = Math.max(...pesos) + 1;
  const xStep = (w - pad*2) / (list.length - 1);
  const pts = list.map((e,i)=>{
    const x = pad + i*xStep;
    const y = h - pad - ((e.peso - min)/(max-min)) * (h - pad*2);
    return [x,y];
  });
  const path = pts.map((pt,i)=> (i===0?'M':'L') + pt[0].toFixed(1) + ',' + pt[1].toFixed(1)).join(' ');
  const dots = pts.map((pt,i)=> `<circle cx="${pt[0]}" cy="${pt[1]}" r="3.5" fill="var(--accent)"><title>${list[i].data}: ${list[i].peso}kg</title></circle>`).join('');
  return `<div class="chartWrap"><svg width="${w}" height="${h}" viewBox="0 0 ${w} ${h}">
    <line x1="${pad}" y1="${h-pad}" x2="${w-pad}" y2="${h-pad}" stroke="var(--line)"/>
    <path d="${path}" fill="none" stroke="var(--accent)" stroke-width="2"/>${dots}</svg></div>`;
}
function renderProgresso(){
  const p = state.perfilAtivo;
  const list = state.progresso[p];

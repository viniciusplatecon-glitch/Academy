function addExercicio(diaId){
  const nome = document.getElementById('ex_nome_'+diaId).value.trim();
  const series = document.getElementById('ex_series_'+diaId).value;
  const reps = document.getElementById('ex_reps_'+diaId).value;
  const carga = document.getElementById('ex_carga_'+diaId).value;
  if(!nome){ toast('Informe o nome do exercício.'); return; }
  const p = state.perfilAtivo;
  const dia = state.treinos[p].find(d=>d.id===diaId);
  dia.exercicios.push({ id: Date.now().toString(36), nome, series, reps, carga, feito:false });
  safeSet('treinos:'+p, state.treinos[p], true);
  render();
}
function delExercicio(diaId, exId){
  const p = state.perfilAtivo;
  const dia = state.treinos[p].find(d=>d.id===diaId);
  dia.exercicios = dia.exercicios.filter(e=>e.id!==exId);
  safeSet('treinos:'+p, state.treinos[p], true);
  render();
}
function toggleExercicioFeito(diaId, exId){
  const p = state.perfilAtivo;
  const dia = state.treinos[p].find(d=>d.id===diaId);
  const ex = dia.exercicios.find(e=>e.id===exId);
  ex.feito = !ex.feito;
  
  if(ex.feito) {
    startTimer(60);
    toast('Exercício feito! Descanso iniciado ⏱️');
  }
  
  safeSet('treinos:'+p, state.treinos[p], true);
  render();
}
function renderWeekStrip(){
  const p = state.perfilAtivo;
  const dates = getWeekDates();
  const today = new Date().toISOString().slice(0,10);
  return `<div class="weekStrip">${dates.map((d,i)=>{
    const done = state.treinoLog[p].includes(d);
    const isToday = d===today;
    return `<div class="dayDot ${done?'done':''} ${isToday?'today':''}" onclick="toggleDia('${d}')">
      <div class="lbl">${DIAS_SEMANA[i]}</div>
      <div class="circ">${new Date(d+'T00:00:00').getDate()}</div>
    </div>`;
  }).join('')}</div>`;
}

function renderTreinos(){
  const p = state.perfilAtivo;
  const dias = state.treinos[p];
  
  const pesoAtual = state.calc[p]?.peso || (p === 'p1' ? 75 : 55);
  const metaAguaMl = Math.round(pesoAtual * 35);
  const aguaConsumida = state.water[p] || 0;
  const pctAgua = Math.min(100, Math.round((aguaConsumida / metaAguaMl) * 100));

  const diasHtml = dias.map(d => `
    <div class="dayCard animated-fade">
      <div class="dayHead"><h3>${d.nome}</h3><button class="iconBtn" onclick="delDia('${d.id}')">✕</button></div>
      <div class="dayBody">
        <div class="exRow"><div></div><div class="h">Exercício</div><div class="h">Séries</div><div class="h">Reps</div><div class="h">Carga</div><div></div></div>
        ${d.exercicios.map(e=>`
          <div class="exRow ${e.feito?'done':''}">
            <input type="checkbox" ${e.feito?'checked':''} onchange="toggleExercicioFeito('${d.id}','${e.id}')">
            <div class="exName">${e.nome}</div><div>${e.series||'—'}</div><div>${e.reps||'—'}</div><div>${e.carga?e.carga+'kg':'—'}</div>
            <button class="iconBtn" onclick="delExercicio('${d.id}','${e.id}')">✕</button>
          </div>`).join('') || '<div class="empty">Sem exercícios ainda.</div>'}
        <hr class="tear">
        <div class="rowGrid">
          <div class="field"><label>Exercício</label><input id="ex_nome_${d.id}" placeholder="ex: Supino reto"></div>
          <div class="field"><label>Séries</label><input id="ex_series_${d.id}" placeholder="ex: 4"></div>
        </div>
        <div class="rowGrid">
          <div class="field"><label>Reps</label><input id="ex_reps_${d.id}" placeholder="ex: 10-12"></div>
          <div class="field"><label>Carga (kg)</label><input id="ex_carga_${d.id}" placeholder="ex: 20"></div>
        </div>
        <button class="btn small" onclick="addExercicio('${d.id}')">Adicionar Exercício</button>
      </div>
    </div>
  `).join('') || '<div class="empty">Nenhum treino criado ainda.</div>';

  const totalMetas = state.metas.length;
  const concluidas = state.metas.filter(m=>m.concluida).length;
  const pctMetas = totalMetas > 0 ? Math.round((concluidas / totalMetas) * 100) : 0;

  return `
    <!-- WIDGET DE HIDRATAÇÃO -->
    <div class="panel animated-fade">
      <h3 style="font-size:13px; margin-bottom:10px;">💧 Hidratação Diária</h3>
      <div class="waterWidget">
        <div style="flex:1;">
          <div style="font-size:11px; color:var(--muted); margin-bottom:4px;">Progresso: ${aguaConsumida}ml / ${metaAguaMl}ml (${pctAgua}%)</div>
          <div class="waterProgress"><div class="waterBar" style="width: ${pctAgua}%;"></div></div>
        </div>
        <div class="btnRow" style="margin-top:0;">
          <button class="btn small" onclick="addWater(250)">+250ml</button>
          <button class="btn small" onclick="addWater(500)">+500ml</button>
          <button class="btn small ghost" onclick="clearWater()">Resetar</button>
        </div>
      </div>
    </div>

    <!-- METAS DO CASAL -->
    <div class="panel animated-fade">
      <h3 style="font-size:13px; margin-bottom:6px;">🎯 Metas Vi & Yas</h3>
      <div style="font-size:11px; color:var(--muted);">${concluidas} de ${totalMetas} conquistadas (${pctMetas}%)</div>
      <div class="progressBar"><div class="progressBarInner" style="width: ${pctMetas}%;"></div></div>
      <div>
        ${state.metas.map(m => `
          <div class="metaRow ${m.concluida?'done':''}">
            <input type="checkbox" ${m.concluida?'checked':''} onchange="toggleMeta('${m.id}')">
            <span style="flex:1; font-size:12.5px;">${m.texto}</span>
            <button class="iconBtn" onclick="delMeta('${m.id}')">✕</button>
          </div>
        `).join('')}
      </div>
      <div class="commentInputWrap" style="margin-top:12px;">
        <input id="new_meta_text" placeholder="Adicionar nova meta para o casal...">
        <button class="btn small" onclick="addMeta()">+ Meta</button>
      </div>
    </div>

    ${renderWeekStrip()}
    
    <div class="panel animated-fade">
      <h3 style="margin-bottom:12px;">Criar novo treino</h3>
      <div class="field">
        <label>Nome do Treino</label>
        <input id="tr_nome" placeholder="ex: Treino A - Peito e Tríceps">
      </div>
      <button class="btn" onclick="addDia()">Criar Treino</button>
    </div>
    
    ${diasHtml}
  `;
}

/* ---------- MURAL ---------- */
let tempImageBase64 = null;

function processImage(input) {
  const file = input.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = function(e) {
    const img = new Image();
    img.onload = function() {
      const canvas = document.createElement('canvas');
      const MAX_WIDTH = 500;
      let width = img.width;
      let height = img.height;

      if (width > MAX_WIDTH) {
        height *= MAX_WIDTH / width;
        width = MAX_WIDTH;
      }
      canvas.width = width;
      canvas.height = height;
      const ctx = canvas.getContext('2d');
      ctx.drawImage(img, 0, 0, width, height);
      
      tempImageBase64 = canvas.toDataURL('image/jpeg', 0.6);
      
      const preview = document.getElementById('mu_preview');
      preview.src = tempImageBase64;
      preview.style.display = 'block';
      document.getElementById('mu_fname').textContent = file.name;
    };
    img.src = e.target.result;
  };
  reader.readAsDataURL(file);
}

function addPost(){
  const text = document.getElementById('mu_text').value.trim();
  if(!text && !tempImageBase64){ toast('Escreva alguma coisa ou adicione uma foto.'); return; }
  
  const post = {
    id: Date.now().toString(36),
    autor: state.perfis[state.perfilAtivo].nome,
    perfil: state.perfilAtivo,
    texto: text,
    img: tempImageBase64,
    data: new Date().toISOString(),
    likes: [],
    comentarios: []
  };

  state.mural.unshift(post);
  safeSet('mural', state.mural, true);
  
  tempImageBase64 = null;
  render();
}

function toggleLike(postId){
  const post = state.mural.find(p => p.id === postId);
  if(!post) return;
  const perfil = state.perfilAtivo;
  const idx = post.likes.indexOf(perfil);
  if(idx > -1) post.likes.splice(idx, 1); else post.likes.push(perfil);
  safeSet('mural', state.mural, true);
  render();
}

function addComment(postId){
  const input = document.getElementById('comm_input_'+postId);
  const text = input.value.trim();
  if(!text) return;
  const post = state.mural.find(p => p.id === postId);
  if(!post) return;
  
  post.comentarios.push({
    id: Date.now().toString(36),
    autor: state.perfis[state.perfilAtivo].nome,
    texto: text
  });

  safeSet('mural', state.mural, true);
  render();
}

function delPost(postId){
  const post = state.mural.find(p => p.id === postId);
  if(!post) return;
  if(post.perfil !== state.perfilAtivo){
    toast('Você só pode apagar suas próprias postagens.');
    return;
  }
  state.mural = state.mural.filter(p => p.id !== postId);
  safeSet('mural', state.mural, true);
  render();
}

function renderMural(){
  const p = state.perfilAtivo;
  const postsHtml = state.mural.map(post => {
    const liked = post.likes.includes(p);
    const dono = post.perfil === p;
    const dataFormatada = new Date(post.data).toLocaleDateString('pt-BR', {hour: '2-digit', minute:'2-digit'});
    const corAutor = state.perfis[post.perfil] ? state.perfis[post.perfil].cor : 'var(--accent)';
    const comentariosArr = post.comentarios || [];
    
    return `
      <div class="postCard animated-fade">
        <div class="postHead">
          <div class="avatar avatarSmall" style="background:${corAutor}">${post.autor[0]}</div>
          <div style="flex:1;">
            <div class="who" style="color:${corAutor}">${post.autor}</div>
            <div class="when">${dataFormatada}</div>
          </div>
          ${dono ? `<button class="iconBtn" onclick="delPost('${post.id}')">✕</button>` : ''}
        </div>
        ${post.img ? `<img class="postImg" src="${post.img}">` : ''}
        ${post.texto ? `<div class="postText">${post.texto}</div>` : ''}
        <div class="postFoot">
          <button class="likeBtn ${liked ? 'liked' : ''}" onclick="toggleLike('${post.id}')">
            🔥 ${post.likes.length}
          </button>
        </div>

        <!-- Comentários -->
        <div class="commentsSec">
          <div class="commentList" id="comm_list_${post.id}">
            ${comentariosArr.map(c => `
              <div class="commentRow">
                <strong>${c.autor}:</strong> <span>${c.texto}</span>
              </div>
            `).join('')}
          </div>
          <div class="commentInputWrap">
            <input id="comm_input_${post.id}" placeholder="Deixe um comentário fofo..." onkeydown="if(event.key==='Enter') addComment('${post.id}')">
            <button class="btn small" onclick="addComment('${post.id}')">Enviar</button>
          </div>
        </div>
      </div>
    `;
  }).join('') || '<div class="empty">Nenhuma foto ou postagem aqui ainda. Publique algo para motivar o seu amor! 🔥</div>';

  return `
    <div class="panel composer animated-fade">
      <h3 style="margin-bottom:12px;">Mural de Fotos e Posts</h3>
      <div class="field">
        <textarea id="mu_text" placeholder="Como foi o treino hoje?"></textarea>
      </div>
      
      <img id="mu_preview" class="previewImg">
      
      <div class="fileRow">
        <label class="btn ghost small" style="cursor:pointer; display:inline-block; width:auto; text-align:center;">
          📸 Adicionar Foto
          <input type="file" accept="image/*" onchange="processImage(this)" style="display:none;">
        </label>
        <div class="fname" id="mu_fname">Nenhuma imagem selecionada</div>
      </div>

      <button class="btn" onclick="addPost()">Postar no Mural</button>
    </div>
    ${postsHtml}
  `;
}

/* ---------- RENDERIZAÇÃO GERAL ---------- */
function toggleMenu(){
  state.menuOpen = !state.menuOpen;
  render();
}

function changeTab(tab){
  state.tab = tab;
  render();
}

function switchPerfil(){
  const outro = state.session === 'p1' ? 'p2' : 'p1';
  state.session = outro;
  state.perfilAtivo = outro;
  state.menuOpen = false;
  applyTheme(outro);
  render();
  toast(`Entrou no perfil do(a) ${state.perfis[outro].nome}`);
}

function renderApp(){
  applyTheme(state.perfilAtivo);
  const p = state.perfilAtivo;
  const perfilObj = state.perfis[p];
  
  let content = '';
  if(state.tab === 'treinos') content = renderTreinos();
  if(state.tab === 'progresso') content = renderProgresso();
  if(state.tab === 'calc') content = renderCalc();
  if(state.tab === 'mural') content = renderMural();

  return `
    <div class="wrap">
      <header class="topbar">
        <div class="left">
          <div class="avatar" style="background:${perfilObj.cor}" onclick="toggleMenu()">${perfilObj.nome[0]}</div>
          <div class="wordmark">Vi & Yas <span>FIT</span></div>
        </div>
        <button class="menuBtn" onclick="toggleMenu()">Menu</button>
      </header>

      <main>${content}</main>

      <!-- CRONÔMETRO FLUTUANTE -->
      <div class="timerBar" id="timerContainer" style="display:none;">
        <div>⏱️ Tempo de Descanso: <span class="time" id="timerDisplay">00:00</span></div>
        <div class="timerBtnRow">
          <button class="btn small" id="timerPlayBtn" onclick="toggleTimerRun()">PAUSAR</button>
          <button class="btn small ghost" onclick="stopTimer()">✕</button>
        </div>
      </div>

      <nav class="bottomNav">
        <div class="bottomNavInner">
          <button class="navBtn ${state.tab==='treinos'?'active':''}" onclick="changeTab('treinos')">
            ${ICONS.treinos}
            <div>Treinos</div>
          </button>
          <button class="navBtn ${state.tab==='progresso'?'active':''}" onclick="changeTab('progresso')">
            ${ICONS.progresso}
            <div>Evolução</div>
          </button>
          <button class="navBtn ${state.tab==='calc'?'active':''}" onclick="changeTab('calc')">
            ${ICONS.calc}
            <div>Macros</div>
          </button>
          <button class="navBtn ${state.tab==='mural'?'active':''}" onclick="changeTab('mural')">
            ${ICONS.mural}
            <div>Mural</div>
          </button>
        </div>
      </nav>

      <!-- MENU LATERAL -->
      <div class="menuOverlay ${state.menuOpen?'open':''}" onclick="toggleMenu()"></div>
      <div class="menuPanel ${state.menuOpen?'open':''}">
        <h3>Opções</h3>
        
        <div class="field" style="margin-top: 10px;">
          <label>Minha Cor Temática</label>
          <div class="color-picker-wrap">
            <input type="color" value="${perfilObj.cor}" onchange="updateColor('${p}', this.value)">
            <span style="font-size:12px;">Escolher cor</span>
          </div>
        </div>

        <div class="menuItem" onclick="switchPerfil()">Alternar Perfil (${p==='p1'?state.perfis.p2.nome:state.perfis.p1.nome})</div>
        
        <div class="tear"></div>
        <h3 style="font-size:12px; margin-bottom:8px;">⏱️ Ativar Cronômetro</h3>
        <div class="btnRow" style="margin-bottom:15px;">
          <button class="btn small" onclick="startTimer(30)">30s</button>
          <button class="btn small" onclick="startTimer(60)">1m</button>
          <button class="btn small" onclick="startTimer(120)">2m</button>
        </div>

        <div class="menuItem danger" onclick="logout()">Sair</div>
      </div>
    </div>
  `;
}

function render(){
  const root = document.getElementById('app');
  if(!state.loaded){
    root.innerHTML = `
      <div class="loader-screen">
        <svg class="runner-icon" viewBox="0 0 24 24">
          <path d="M13.49 5.48c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm-3.6 13.9l.89-4.25-1.99-1c-.5-.25-.7-.85-.45-1.35l1-2c.4-.8 1.25-1.28 2.15-1.28H15c.55 0 1 .45 1 1v2.5h2c.55 0 1 .45 1 1s-.45 1-1 1h-2.5c-.55 0-1-.45-1-1v-2h-.6l-1.4 7H9.89zm1.42 2.22l.5-2.5h3.6l1.2 6H15.1l-1.5-4.5-2.29-1.28z"/>
        </svg>
        <div style="font-family:'Oswald', sans-serif; font-size:16px; letter-spacing:0.1em; text-transform:uppercase;">Preparando seu Treino...</div>
      </div>
    `;
    return;
  }
  if(!state.session){
    applyTheme(null);
    root.innerHTML = renderLogin();
  } else {
    root.innerHTML = renderApp();
    updateTimerUI();
  }
}

loadAll();
</script>

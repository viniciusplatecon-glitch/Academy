/* ---------- CALCULADORA COM ANIMAÇÃO ---------- */
function onFormulaChange(){
  const f = document.getElementById('c_formula').value;
  document.getElementById('gordura_field').style.display = (f === 'katch') ? 'block' : 'none';
}
function calcularTMB(formula, peso, altura, idade, sexo, gordura){
  if(formula === 'harris'){
    return sexo === 'M'
      ? 88.362 + 13.397*peso + 4.799*altura - 5.677*idade
      : 447.593 + 9.247*peso + 3.098*altura - 4.330*idade;
  }
  if(formula === 'katch'){
    const massaMagra = peso * (1 - (gordura||0)/100);
    return 370 + 21.6*massaMagra;
  }
  return (10*peso) + (6.25*altura) - (5*idade) + (sexo === 'M' ? 5 : -161);
}
function calcular(){
  const peso = parseFloat(document.getElementById('c_peso').value);
  const altura = parseFloat(document.getElementById('c_altura').value);
  const idade = parseInt(document.getElementById('c_idade').value);
  const sexo = document.getElementById('c_sexo').value;
  const fator = parseFloat(document.getElementById('c_atividade').value);
  const meta = document.getElementById('c_meta').value;
  const ajuste = parseInt(document.getElementById('c_ajuste').value) || 0;
  const formula = document.getElementById('c_formula').value;
  const gordura = parseFloat(document.getElementById('c_gordura').value) || 0;
  if(!peso || !altura || !idade){ toast('Preencha peso, altura e idade.'); return; }
  if(formula === 'katch' && !gordura){ toast('Informe o % de gordura corporal pra usar Katch-McArdle.'); return; }
  
  // Ativa a animação de cálculo antes de salvar os dados
  state.calculando = true;
  render();

  setTimeout(() => {
    const tmb = calcularTMB(formula, peso, altura, idade, sexo, gordura);
    const get = tmb * fator;
    let alvo = get;
    if(meta === 'ganhar') alvo = get + ajuste;
    if(meta === 'perder') alvo = get - ajuste;
    
    const result = { peso, altura, idade, sexo, fator, meta, ajuste, formula, gordura,
      tmb: Math.round(tmb), get: Math.round(get), alvo: Math.round(alvo), data: new Date().toISOString() };
    
    state.calc[state.perfilAtivo] = result;
    safeSet('calc:'+state.perfilAtivo, result, true);
    state.calculando = false;
    render();
  }, 1500); // 1.5 segundos exibindo a animação dos halteres/garrafa
}

